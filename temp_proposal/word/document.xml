/w:tcPr><w:p w14:paraId="206AED50" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Xie et al.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1800" w:type="dxa"/></w:tcPr><w:p w14:paraId="411EDD18" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Multi‑feature fusion approach to improve engagement prediction reliability.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1540" w:type="dxa"/></w:tcPr><w:p w14:paraId="5814C30D" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>scholar.google.com</w:t></w:r></w:p></w:tc></w:tr><w:tr w:rsidR="00F018BB" w14:paraId="12DBB11E" w14:textId="77777777"><w:tc><w:tcPr><w:tcW w:w="1900" w:type="dxa"/></w:tcPr><w:p w14:paraId="1AC6C038" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Student Engagement Detection Using EfficientNetV2 and RNN</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="550" w:type="dxa"/></w:tcPr><w:p w14:paraId="55C8F1AB" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>2024</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1350" w:type="dxa"/></w:tcPr><w:p w14:paraId="18EC1859" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>EfficientNetV2 with RNN</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="800" w:type="dxa"/></w:tcPr><w:p w14:paraId="346EBF09" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>E‑learning dataset</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="700" w:type="dxa"/></w:tcPr><w:p w14:paraId="17A398A9" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Shiri et al.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1800" w:type="dxa"/></w:tcPr><w:p w14:paraId="7A243D72" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>CNN and RNN combined to analyze engagement patterns in online learning.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1540" w:type="dxa"/></w:tcPr><w:p w14:paraId="5B562524" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>scholar.google.com</w:t></w:r></w:p></w:tc></w:tr><w:tr w:rsidR="00F018BB" w14:paraId="4A26EBDA" w14:textId="77777777"><w:tc><w:tcPr><w:tcW w:w="1900" w:type="dxa"/></w:tcPr><w:p w14:paraId="112699FA" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>AI‑Based Engagement Detection Using CNNs</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="550" w:type="dxa"/></w:tcPr><w:p w14:paraId="10EDC9A4" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>2024</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1350" w:type="dxa"/></w:tcPr><w:p w14:paraId="0D5D4670" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>CNN based classification</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="800" w:type="dxa"/></w:tcPr><w:p w14:paraId="4E63F075" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Classroom video dataset</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="700" w:type="dxa"/></w:tcPr><w:p w14:paraId="6B0C9410" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Hara Gopal et al.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1800" w:type="dxa"/></w:tcPr><w:p w14:paraId="5C9928AA" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>CNN models effectively distinguish attentive from distracted students.</w:t></w:r></w:p></w:tc><w:tc><w:tcPr><w:tcW w:w="1540" w:type="dxa"/></w:tcPr><w:p w14:paraId="7AB9EF86" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>scholar.google.com</w:t></w:r></w:p></w:tc></w:tr></w:tbl><w:p w14:paraId="5232F3EB" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:lastRenderedPageBreak/><w:t>Has This Idea Been Implemented Before?</w:t></w:r></w:p><w:p w14:paraId="07C46387" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Yes, this concept has been explored by several researchers. Many existing systems use computer vision to examine facial expressions, eye gaze, and head pose, with reported accuracy rates typically ranging between 85% and 95%. However, most prior work focuses solely on facial analysis or online learning scenarios.</w:t></w:r></w:p><w:p w14:paraId="142AEDC4" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>This project extends those approaches by integrating facial expression analysis with object detection (e.g., identifying mobile phones) and computing an overall classroom attention score that reflects the engagement level of the entire class.</w:t></w:r></w:p><w:p w14:paraId="4DF022C3" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>Proposed Methodology</w:t></w:r></w:p><w:p w14:paraId="10727347" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>The proposed solution will employ computer vision and deep learning methods to analyze classroom images and determine the attention level of students.</w:t></w:r></w:p><w:p w14:paraId="11BD1581" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>In the first stage, classroom images will be collected through a webcam feed or via user uploads through a web interface. Before analysis, images will undergo preprocessing steps such as resizing, normalization, and noise reduction to ensure suitability for deep learning models.</w:t></w:r></w:p><w:p w14:paraId="1DEEBDDF" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>In the second stage, face detection techniques using OpenCV or YOLO will locate student faces within the image. A convolutional neural network will then classify each student’s attention state into categories such as attentive, distracted, looking away, or sleeping.</w:t></w:r></w:p><w:p w14:paraId="6AF6DCD7" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>In addition, an object detection module will identify potential distractions in the classroom environment, such as mobile phones. Outputs from both the facial analysis and object detection modules will be combined to calculate an overall classroom attention score.</w:t></w:r></w:p><w:p w14:paraId="1B83133A" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Finally, the system will be deployed as a web‑based application using Flask or FastAPI, returning visual results that show detected faces, identified objects, and predicted engagement levels.</w:t></w:r></w:p><w:p w14:paraId="0E8559F0" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:pPr><w:pStyle w:val="Heading1"/></w:pPr><w:r><w:t>References</w:t></w:r></w:p><w:p w14:paraId="2CD7F2B4" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Uçar, M. U., &amp; Özdemir, E. (2022). Recognizing Students and Detecting Student Engagement. Electronics.</w:t></w:r></w:p><w:p w14:paraId="5810FC4E" w14:textId="77777777" w:rsidR="00442DCD" w:rsidRDefault="00000000"><w:r><w:t>Ikram, S., Ahmad, H., Mahmood, N., Faisal, C., Abbas, Q., Qureshi, I., &amp; Hussain, A. (2023). Student Engagement State Recognition Using Transfer Learning. Applied Sciences.</w:t></w:r></w:p><w:p w14:paraId="0F6D3C45" w14:textId="5E9D6AA4" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Xie, N., Liu, Z., Li, Z., Pang, W., &amp; Lu, B. (2023). Engagement Detection via Computer Vision and Feature Fusion. Multimedia Systems.</w:t></w:r></w:p><w:p w14:paraId="6CADD6D7" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:t>Shiri, F. M., Ahmadi, E., Rezaee, M., &amp; Perumal, T. (2024). Student Engagement Detection Using EfficientNetV2 and RNN Models. Journal on Artificial Intelligence.</w:t></w:r></w:p><w:p w14:paraId="6417E3A6" w14:textId="77777777" w:rsidR="00F018BB" w:rsidRDefault="00000000"><w:r><w:lastRenderedPageBreak/><w:t>Hara Gopal, V. P., Arun Babu, P., Anays, S. M., Hussian, P. J., Hemanjali, M., &amp; Charan, M. S. (2024). AI‑Based Student Engagement Detection Using Convolutional Neural Network Models for Classroom Analytics.</w:t></w:r></w:p><w:sectPr w:rsidR="00F018BB" w:rsidSect="00034616"><w:pgSz w:w="12240" w:h="15840"/><w:pgMar w:top="1440" w:right="1800" w:bottom="1440" w:left="1800" w:header="720" w:footer="720" w:gutter="0"/><w:cols w:space="720"/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>